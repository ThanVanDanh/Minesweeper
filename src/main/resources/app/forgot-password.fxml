<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="minesweeper.controller.ForgotPasswordController"
      styleClass="dialog-content"
      stylesheets="@../css/login.css"
      spacing="12">

    <!-- Title -->
    <Label text="? QUÊN MẬT KHẨU" styleClass="dialog-title"/>

    <!-- Header -->
    <Label text="Nhập email để khôi phục mật khẩu" styleClass="dialog-header"/>

    <!-- Info text -->
    <Label text="Chúng tôi sẽ gửi link đặt lại mật khẩu đến email của bạn. Link sẽ hết hạn trong 30 phút."
           styleClass="dialog-info"
           wrapText="true"/>

    <!-- Email input section -->
    <VBox spacing="8">
        <Label text="Địa chỉ Email:" styleClass="input-label"/>
        <TextField fx:id="emailField"
                   promptText="your@email.com"
                   styleClass="dialog-input"/>
    </VBox>

    <!-- Buttons container -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="sendButton"
                text="📧 GỬI LINK"
                styleClass="dialog-button"
                onAction="#handleSendLink"/>
        <Button fx:id="cancelButton"
                text="✕ HUỶ"
                styleClass="dialog-secondary-button"
                onAction="#handleCancel"/>
    </HBox>

</VBox>

