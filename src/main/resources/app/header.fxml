<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" spacing="20" styleClass="top-nav" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand-box">
        <StackPane styleClass="brand-icon">
            <Label styleClass="brand-symbol" text="💣" />
        </StackPane>
        <VBox alignment="CENTER_LEFT">
            <Label styleClass="brand-title" text="MINESWEEPER" />
            <Label styleClass="brand-subtitle" text="TACTICAL GRID v2.0" />
        </VBox>
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER" spacing="5" styleClass="nav-menu">
        <Button styleClass="nav-button" text="☷ Dashboard" />
        <Button styleClass="nav-button-selected" text="▶ Chơi" />
        <Button styleClass="nav-button" text="🏆 Bảng Xếp Hạng" />
        <Button styleClass="nav-button" text="⏱ Lịch Sử" />
        <Button styleClass="nav-button" text="⚙ Cài Đặt" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER" spacing="10">
        <Button styleClass="outline-button" text="→] Đăng Nhập" />
        <Button styleClass="primary-button-small" text="👤+ Đăng Ký" />
    </HBox>
</HBox>