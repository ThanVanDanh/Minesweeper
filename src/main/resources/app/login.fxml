<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
        fx:id="authRoot"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="minesweeper.controller.LoginController"
        stylesheets="@../css/login.css"
        styleClass="auth-root">

    <VBox styleClass="auth-card" maxWidth="460" spacing="18">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="MINESWEEPER" styleClass="brand-title"/>
                <Label text="TACTICAL GRID ACCESS" styleClass="brand-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="×" onAction="#closePopup" styleClass="close-button"/>
        </HBox>

        <VBox spacing="6">
            <Label fx:id="formTitle" text="ĐĂNG NHẬP" styleClass="form-title"/>
            <Label fx:id="formSubtitle"
                   text="Truy cập hồ sơ chiến thuật của bạn"
                   styleClass="form-subtitle"/>
        </VBox>

        <HBox styleClass="switch-wrapper" spacing="8">
            <Button fx:id="loginTabButton"
                    text="Đăng Nhập"
                    onAction="#showLoginForm"
                    styleClass="switch-button-active"/>
            <Button fx:id="registerTabButton"
                    text="Đăng Ký"
                    onAction="#showRegisterForm"
                    styleClass="switch-button"/>
        </HBox>

        <!-- ═══════════════ LOGIN FORM ═══════════════ -->
        <VBox fx:id="loginForm" spacing="14">

            <VBox spacing="6">
                <Label text="TÊN ĐĂNG NHẬP" styleClass="input-label"/>
                <TextField fx:id="loginUsernameField"
                           promptText="pilot@minesweeper.grid"
                           styleClass="auth-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="MẬT KHẨU" styleClass="input-label"/>
                <PasswordField fx:id="loginPasswordField"
                               promptText="••••••••"
                               styleClass="auth-input"/>
            </VBox>

            <!--
                fx:id="rememberMeCheckBox" → controller dùng để đọc trạng thái
            -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <CheckBox fx:id="rememberMeCheckBox"
                          text="Ghi nhớ đăng nhập"
                          styleClass="auth-check"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Quên mật khẩu?" onAction="#handleForgotPassword" styleClass="link-button"/>
            </HBox>

            <Button text="ĐĂNG NHẬP →"
                    onAction="#handleLogin"
                    styleClass="primary-auth-button"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Chưa có tài khoản?" styleClass="muted-text"/>
                <Button text="Tạo tài khoản mới"
                        onAction="#showRegisterForm"
                        styleClass="link-button"/>
            </HBox>

        </VBox>

        <!-- ═══════════════ REGISTER FORM ═══════════════ -->
        <VBox fx:id="registerForm" spacing="14" visible="false" managed="false">

            <VBox spacing="6">
                <Label text="TÊN ĐĂNG NHẬP" styleClass="input-label"/>
                <TextField fx:id="registerUsernameField"
                           promptText="pilot_neo"
                           styleClass="auth-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="TÊN NGƯỜI CHƠI" styleClass="input-label"/>
                <TextField fx:id="registerDisplayNameField"
                           promptText="NightSapper"
                           styleClass="auth-input"/>
            </VBox>

            <!--
                FIELD MỚI: Email — fx:id="registerEmailField"
            -->
            <VBox spacing="6">
                <Label text="EMAIL XÁC NHẬN" styleClass="input-label"/>
                <TextField fx:id="registerEmailField"
                           promptText="pilot@example.com"
                           styleClass="auth-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="MẬT KHẨU" styleClass="input-label"/>
                <PasswordField fx:id="registerPasswordField"
                               promptText="••••••••"
                               styleClass="auth-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="XÁC NHẬN MẬT KHẨU" styleClass="input-label"/>
                <PasswordField fx:id="registerConfirmPasswordField"
                               promptText="••••••••"
                               styleClass="auth-input"/>
            </VBox>

            <CheckBox fx:id="termsCheckBox"
                      text="Tôi đồng ý với điều khoản chiến thuật"
                      styleClass="auth-check"/>

            <Button text="TẠO TÀI KHOẢN →"
                    onAction="#handleRegister"
                    styleClass="primary-auth-button"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Đã có tài khoản?" styleClass="muted-text"/>
                <Button text="Đăng nhập ngay"
                        onAction="#showLoginForm"
                        styleClass="link-button"/>
            </HBox>

        </VBox>

    </VBox>

    <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="12" style="-fx-background-color: rgba(5, 10, 18, 0.85); -fx-background-radius: 16px;" visible="false">
        <ProgressIndicator prefWidth="50" prefHeight="50"/>
        <Label fx:id="loadingLabel" text="Đang xử lý..." style="-fx-text-fill: #2dd4f0; -fx-font-size: 15px; -fx-font-weight: bold;"/>
    </VBox>

</StackPane>
