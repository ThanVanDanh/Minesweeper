<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="minesweeper.controller.AdminResultController"
      styleClass="root-bg"
      spacing="0">

    <!-- Header bar -->
    <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="14">
        <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
        <Label text="📋" style="-fx-font-size:18;"/>
        <Label text="QUẢN LÝ KẾT QUẢ" styleClass="section-title-orange"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" styleClass="selected-mode"/>
    </HBox>

    <!-- Body -->
    <VBox spacing="14" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="30" bottom="24" left="30"/></padding>

        <!-- Filter panel -->
        <VBox styleClass="panel-card" spacing="0">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <HBox spacing="16" alignment="CENTER_LEFT">

                <VBox spacing="5">
                    <Label text="ĐỘ KHÓ" style="-fx-text-fill: white;" styleClass="input-label"/>
                    <ComboBox fx:id="cbDifficulty" prefWidth="148"
                              style="-fx-background-color:rgba(3,16,25,0.95);-fx-border-color:rgba(33,217,255,0.25);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#d7fbff;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="USERNAME" style="-fx-text-fill: white;" styleClass="input-label"/>
                    <TextField fx:id="tfUsername" promptText="Nhập username..." prefWidth="220" styleClass="auth-input"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="KẾT QUẢ" style="-fx-text-fill: white;"  styleClass="input-label"/>
                    <ComboBox fx:id="cbResult" prefWidth="130"
                              style="-fx-background-color:rgba(3,16,25,0.95);-fx-border-color:rgba(33,217,255,0.25);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#d7fbff;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox spacing="8" alignment="BOTTOM_RIGHT">
                    <Button text="▷  LỌC"      onAction="#onFilter" styleClass="start-button" prefWidth="110"/>
                    <Button text="↺  Đặt lại"  onAction="#onReset"  styleClass="nav-button"   prefWidth="110"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Toolbar -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="panel-card">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Button text="☑  Chọn / Bỏ chọn tất cả" onAction="#onSelectAll" styleClass="outline-button"/>
            <Label fx:id="selectedCountLabel" text="0 đã chọn" styleClass="selected-mode" style="-fx-padding:0 8;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⚑  XÓA GIAN LẬN" onAction="#onDeleteFraud"
                    style="-fx-background-color:rgba(198,40,40,0.18);-fx-border-color:rgba(198,40,40,0.7);-fx-border-radius:5;-fx-background-radius:5;-fx-text-fill:#ef5350;-fx-font-weight:900;-fx-padding:9 16;-fx-cursor:hand;"/>
        </HBox>

        <!-- Table -->
        <VBox styleClass="panel-card" VBox.vgrow="ALWAYS">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <TableView fx:id="resultTable" editable="true" VBox.vgrow="ALWAYS" minHeight="400"
                       style="-fx-background-color:transparent;-fx-control-inner-background:#030f18;-fx-control-inner-background-alt:#050e17;-fx-table-cell-border-color:rgba(45,212,240,0.08);-fx-text-fill:#c8eef7;-fx-selection-bar:rgba(45,212,240,0.18);-fx-selection-bar-non-focused:rgba(45,212,240,0.10);-fx-focus-color:transparent;-fx-faint-focus-color:transparent;">
                <columns>
                    <TableColumn fx:id="colSelect"     text="✓"         prefWidth="50"  style="-fx-alignment:CENTER;-fx-text-fill: white;"/>
                    <TableColumn fx:id="colGameId"     text="Game ID"   prefWidth="80"/>
                    <TableColumn fx:id="colUsername"   text="Username"  prefWidth="140"/>
                    <TableColumn fx:id="colDifficulty" text="Độ khó"    prefWidth="110"/>
                    <TableColumn fx:id="colScore"      text="Điểm"      prefWidth="80"  style="-fx-alignment:CENTER_RIGHT;-fx-text-fill: white;"/>
                    <TableColumn fx:id="colTime"       text="Thời gian" prefWidth="90"  style="-fx-alignment:CENTER;-fx-text-fill: white;"/>
                    <TableColumn fx:id="colResult"     text="Kết quả"   prefWidth="90"  style="-fx-alignment:CENTER;-fx-text-fill: white;"/>
                    <TableColumn fx:id="colPlayedAt"   text="Ngày chơi" prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Không tìm thấy dữ liệu."
                           style="-fx-text-fill:rgba(45,212,240,0.45);-fx-font-size:13;"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>
</VBox>
