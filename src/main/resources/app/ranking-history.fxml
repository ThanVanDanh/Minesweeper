<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="minesweeper.ranking.controller.RankingHistoryController"
            prefWidth="1100.0" prefHeight="720.0">
    <top>
        <VBox spacing="6">
            <padding>
                <Insets top="18" right="24" bottom="12" left="24"/>
            </padding>
            <Label text="BẢNG XẾP HẠNG &amp; LỊCH SỬ CHƠI" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Dữ liệu được lấy trực tiếp từ MySQL" style="-fx-opacity: 0.75;"/>
        </VBox>
    </top>
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Xếp hạng">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Level:"/>
                                <ComboBox fx:id="levelCombo" prefWidth="240"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <TableView fx:id="rankingTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colRank" text="Hạng" prefWidth="80"/>
                                    <TableColumn fx:id="colPlayerName" text="Người chơi" prefWidth="220"/>
                                    <TableColumn fx:id="colTotalGames" text="Tổng ván" prefWidth="100"/>
                                    <TableColumn fx:id="colWins" text="Thắng" prefWidth="80"/>
                                    <TableColumn fx:id="colScore" text="Điểm" prefWidth="100"/>
                                    <TableColumn fx:id="colWinRate" text="Tỷ lệ thắng" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Lịch sử">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Người chơi:"/>
                                <ComboBox fx:id="playerCombo" prefWidth="240"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colDate" text="Thời gian" prefWidth="180"/>
                                    <TableColumn fx:id="colDifficulty" text="Độ khó" prefWidth="110"/>
                                    <TableColumn fx:id="colResult" text="Kết quả" prefWidth="90"/>
                                    <TableColumn fx:id="colTime" text="Thời gian chơi" prefWidth="120"/>
                                    <TableColumn fx:id="colHistoryScore" text="Điểm" prefWidth="90"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Thống kê">
                    <content>
                        <VBox spacing="14">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Người chơi:"/>
                                <ComboBox fx:id="statsPlayerCombo" prefWidth="240"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <GridPane hgap="16" vgap="14">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>
                                <VBox spacing="4">
                                    <Label text="Tổng ván"/>
                                    <Label fx:id="statsTotalGames" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </VBox>
                                <VBox spacing="4" GridPane.columnIndex="1">
                                    <Label text="Thắng / Thua"/>
                                    <Label fx:id="statsWins" text="0 / 0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </VBox>
                                <VBox spacing="4" GridPane.rowIndex="1">
                                    <Label text="Tỷ lệ thắng"/>
                                    <Label fx:id="statsWinRate" text="0%" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </VBox>
                                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label text="Điểm cao nhất"/>
                                    <Label fx:id="statsBestScore" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </VBox>
                                <VBox spacing="4" GridPane.rowIndex="2">
                                    <Label text="Thời gian trung bình"/>
                                    <Label fx:id="statsAvgTime" text="0 giây" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>


