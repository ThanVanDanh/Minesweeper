<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="minesweeper.controller.AdminUserController"
           style="-fx-background-color:rgba(0,0,0,0.6);"
           prefWidth="1100" prefHeight="720">
    <VBox maxWidth="1060" maxHeight="680"
          style="-fx-background-color: linear-gradient(to bottom right, rgba(5,20,28,0.98), rgba(5,10,18,0.98));
                 -fx-background-radius:12;
                 -fx-border-radius:12;
                 -fx-border-width:1.2;
                 -fx-border-color:rgba(48,255,170,0.45);
                 -fx-effect:dropshadow(gaussian,rgba(39,255,185,0.35),30,0.2,0,0);">

        <!-- Header bar -->
        <HBox styleClass="top-nav" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="14" right="30" bottom="14" left="30"/></padding>
            <Label text="👤" style="-fx-font-size:18;"/>
            <Label text="QUẢN LÝ NGƯỜI DÙNG" styleClass="section-title-green"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="" styleClass="selected-mode"/>
            <Button text="×" onAction="#closePopup" styleClass="close-button"/>
        </HBox>

        <!-- Body -->
        <VBox spacing="14" VBox.vgrow="ALWAYS">
            <padding><Insets top="20" right="30" bottom="24" left="30"/></padding>

            <VBox styleClass="panel-card" spacing="0">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="5">
                        <Label text="TÌM KIẾM" styleClass="input-label" style="-fx-text-fill:white;"/>
                        <TextField fx:id="searchField"
                                   promptText="Tìm theo username hoặc tên hiển thị..."
                                   prefWidth="320"
                                   styleClass="auth-input"
                                   onKeyReleased="#onSearch"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="VAI TRÒ" styleClass="input-label" style="-fx-text-fill:white;"/>
                        <ComboBox fx:id="cbRoleFilter" prefWidth="140"
                                  style="-fx-background-color:rgba(3,16,25,0.95);-fx-border-color:rgba(33,217,255,0.25);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#d7fbff;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="TRẠNG THÁI" styleClass="input-label" style="-fx-text-fill:white;"/>
                        <ComboBox fx:id="cbStatusFilter" prefWidth="140"
                                  style="-fx-background-color:rgba(3,16,25,0.95);-fx-border-color:rgba(33,217,255,0.25);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#d7fbff;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox spacing="8" alignment="BOTTOM_RIGHT">
                        <Button text="▷  Lọc"     onAction="#onSearch"  styleClass="start-button" prefWidth="110"/>
                        <Button text="↺  Đặt lại" onAction="#onRefresh" styleClass="nav-button"   prefWidth="110"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Action toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="panel-card">
                <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
                <Button text="➕  Thêm user"  onAction="#onAddUser"    styleClass="start-button"  prefWidth="130" style="-fx-font-size:12;"/>
                <Button text="✏  Sửa"         onAction="#onEditUser"   styleClass="outline-button" prefWidth="100" style="-fx-font-size:12;"/>
                <Button text="🔒  Khoá/Mở"    onAction="#onLockUser"   styleClass="nav-button"    prefWidth="110" style="-fx-font-size:12;"/>
                <Button text="🗑  Xoá"         onAction="#onDeleteUser"
                        style="-fx-background-color:rgba(198,40,40,0.18);-fx-border-color:rgba(198,40,40,0.7);-fx-border-radius:5;-fx-background-radius:5;-fx-text-fill:#ef5350;-fx-font-weight:900;-fx-font-size:12;-fx-padding:9 16;-fx-cursor:hand;"
                        prefWidth="100"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalUsersLabel"  text="-" style="-fx-text-fill:#39ff8f;-fx-font-size:13;-fx-font-weight:900;"/>
                <Label text="tổng" styleClass="selected-mode"/>
                <Label text=" | " styleClass="selected-mode"/>
                <Label fx:id="activeUsersLabel" text="-" style="-fx-text-fill:#2dd4f0;-fx-font-size:13;-fx-font-weight:900;"/>
                <Label text="hoạt động" styleClass="selected-mode"/>
                <Label text=" | " styleClass="selected-mode"/>
                <Label fx:id="lockedUsersLabel" text="-" style="-fx-text-fill:#ef5350;-fx-font-size:13;-fx-font-weight:900;"/>
                <Label text="khoá" styleClass="selected-mode"/>
                <Label text=" | " styleClass="selected-mode"/>
                <Label fx:id="adminCountLabel"  text="-" style="-fx-text-fill:#ff9d2e;-fx-font-size:13;-fx-font-weight:900;"/>
                <Label text="admin" styleClass="selected-mode"/>
            </HBox>

            <!-- Table -->
            <VBox styleClass="panel-card" VBox.vgrow="ALWAYS">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:transparent;-fx-control-inner-background:#030f18;-fx-control-inner-background-alt:#050e17;-fx-table-cell-border-color:rgba(45,212,240,0.08);-fx-text-fill:#c8eef7;-fx-font-size:12;-fx-selection-bar:transparent;-fx-selection-bar-text:#2dd4f0;-fx-selection-bar-non-focused:transparent;-fx-focus-color:transparent;-fx-faint-focus-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colSelect"      text=""             minWidth="40" maxWidth="40"/>
                        <TableColumn fx:id="colId"          text="ID"           prefWidth="50"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colUsername"    text="Username"     prefWidth="160"/>
                        <TableColumn fx:id="colDisplayName" text="Tên hiển thị" prefWidth="180"/>
                        <TableColumn fx:id="colRole"        text="Vai trò"      prefWidth="130" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colStatus"      text="Trạng thái"   prefWidth="120" style="-fx-alignment:CENTER;"/>
                    </columns>
                    <placeholder>
                        <Label text="Không tìm thấy người dùng phù hợp."
                               style="-fx-text-fill:rgba(45,212,240,0.45);-fx-font-size:12;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Pagination bar -->
            <HBox spacing="10" alignment="CENTER" styleClass="panel-card" minHeight="50" maxHeight="50">
                <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
                <Button fx:id="btnPrevPage" text="◀ Trước" onAction="#onPrevPage" styleClass="nav-button"/>
                <Label fx:id="pageLabel" text="Trang 1 / 1" styleClass="selected-mode"/>
                <Button fx:id="btnNextPage" text="Sau ▶"   onAction="#onNextPage" styleClass="nav-button"/>
            </HBox>

        </VBox>
    </VBox>

</StackPane>