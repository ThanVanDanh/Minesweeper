<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="minesweeper.controller.DashBoardController"
           styleClass="root-bg">

    <BorderPane fx:id="rootPane" styleClass="app-shell">
        <top>
            <VBox>
                <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-nav">
                    <padding>
                        <Insets top="12" right="34" bottom="12" left="34"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand-box">
                        <StackPane styleClass="brand-icon">
                            <Label text="●" styleClass="brand-symbol"/>
                        </StackPane>
                        <VBox spacing="0">
                            <Label text="MINESWEEPER" styleClass="brand-title"/>
                            <Label text="TACTICAL GRID v2.0" styleClass="brand-subtitle"/>
                        </VBox>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox alignment="CENTER" spacing="6" styleClass="nav-menu">
                        <Button text="▦ Dashboard" styleClass="nav-button-selected"/>
                        <Button text="▷ Chơi" styleClass="nav-button"/>
                        <Button text="🏆 Bảng Xếp Hạng" styleClass="nav-button"/>
                        <Button text="↺ Lịch Sử" styleClass="nav-button"/>
                        <Button text="⚙ Cài đặt" styleClass="nav-button"/>
                        <Button text="👤 Quản lý User" onAction="#openAdminUser"   styleClass="nav-button"/>
                        <Button text="📋 Quản lý KQ"   onAction="#openAdminResult" styleClass="nav-button"/>
                    </HBox>

<!--                    <Region HBox.hgrow="ALWAYS"/>-->

<!--                    <HBox alignment="CENTER_RIGHT" spacing="10">-->
<!--                        <Button text="Đăng Nhập" onAction="#openLoginPopup" styleClass="outline-button-large"/>-->
<!--                        <Button text="Đăng Ký" onAction="#openRegisterPopup" styleClass="primary-button-large"/>-->
<!--                    </HBox>-->
                </HBox>
                <Separator styleClass="nav-separator"/>
            </VBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-shell">
                <VBox spacing="22" styleClass="content-wrap">
                    <padding>
                        <Insets top="22" right="38" bottom="34" left="38"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" styleClass="hero-card">
                        <VBox spacing="7">
                            <Label text="MINESWEEPER TACTICAL" styleClass="hero-title"/>
                            <Label text="Thử thách trí tuệ chiến thuật của bạn. Khám phá bãi mìn. Sống sót."
                                   styleClass="hero-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="Đăng Nhập" onAction="#openLoginPopup" styleClass="outline-button-large"/>
                            <Button text="Bắt đầu Ngay →" onAction="#openRegisterPopup" styleClass="primary-button-large"/>
                        </HBox>
                    </HBox>

                    <HBox spacing="18" alignment="TOP_CENTER">
                        <VBox spacing="18" HBox.hgrow="ALWAYS" maxWidth="850">
                            <VBox spacing="15" styleClass="panel-card">
                                <padding>
                                    <Insets top="18" right="18" bottom="18" left="18"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="◇" styleClass="section-icon-green"/>
                                    <Label text="CHỌN ĐỘ KHÓ" styleClass="section-title-green"/>
                                </HBox>

                                <GridPane hgap="5" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="50"/>
                                        <ColumnConstraints percentWidth="50"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>

                                    <ToggleButton fx:id="easyButton" text="●  DỄ&#10;     9×9 | 10 Min"
                                                  GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity"
                                                  styleClass="difficulty-button"/>
                                    <ToggleButton fx:id="mediumButton" text="●  TRUNG BÌNH&#10;     16×16 | 40 Min"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"
                                                  styleClass="difficulty-button"/>
                                    <ToggleButton fx:id="hardButton" text="●  KHÓ&#10;     16×30 | 99 Min"
                                                  GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"
                                                  styleClass="difficulty-button"/>
                                    <ToggleButton fx:id="expertButton" text="●  CHUYÊN GIA&#10;     20×30 | 145 Min"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"
                                                  styleClass="difficulty-button"/>
                                    <ToggleButton fx:id="customButton" text="⚡  TÙY CHỈNH&#10;     Tự thiết lập"
                                                  GridPane.columnIndex="0" GridPane.rowIndex="2" maxWidth="Infinity"
                                                  styleClass="difficulty-button"/>
                                </GridPane>

                                <Button text="▷ BẮT ĐẦU CHIẾN ĐẤU" onAction="#onStartBattle" maxWidth="Infinity"
                                        styleClass="start-button"/>
                                <Label fx:id="selectedModeLabel" text="Chế độ đã chọn: TRUNG BÌNH - 16×16 | 40 Min"
                                       styleClass="selected-mode"/>
                            </VBox>

                            <VBox spacing="16" styleClass="activity-panel">
                                <padding>
                                    <Insets top="18" right="18" bottom="18" left="18"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="⌁" styleClass="section-icon-cyan"/>
                                    <Label text="HOẠT ĐỘNG 7 NGÀY" styleClass="section-title-cyan"/>
                                </HBox>
                                <Pane minHeight="74" styleClass="chart-area">
                                    <HBox alignment="BOTTOM_CENTER" spacing="82" layoutX="40" layoutY="12">
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="28" styleClass="chart-bar"/>
                                            <Label text="T2" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="42" styleClass="chart-bar"/>
                                            <Label text="T3" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="25" styleClass="chart-bar"/>
                                            <Label text="T4" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="58" styleClass="chart-bar-hot"/>
                                            <Label text="T5" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="35" styleClass="chart-bar"/>
                                            <Label text="T6" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="48" styleClass="chart-bar"/>
                                            <Label text="T7" styleClass="chart-label"/>
                                        </VBox>
                                        <VBox alignment="BOTTOM_CENTER" spacing="8">
                                            <Region prefWidth="15" prefHeight="64" styleClass="chart-bar-hot"/>
                                            <Label text="CN" styleClass="chart-label"/>
                                        </VBox>
                                    </HBox>
                                </Pane>
                            </VBox>
                        </VBox>

                        <VBox spacing="18" prefWidth="365" maxWidth="390">
                            <VBox spacing="14" styleClass="side-panel">
                                <padding>
                                    <Insets top="18" right="18" bottom="18" left="18"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Label text="🏆" styleClass="section-icon-orange"/>
                                        <Label text="BẢNG XẾP HẠNG" styleClass="section-title-orange"/>
                                    </HBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Xem tất cả ›" styleClass="side-link"/>
                                </HBox>

                                <VBox spacing="7">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="rank-row rank-row-first">
                                        <Label text="1" styleClass="rank-badge-gold"/>
                                        <VBox spacing="1">
                                            <Label text="NightSapper" styleClass="rank-name-gold"/>
                                            <Label text="LV.42" styleClass="rank-meta"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="1">
                                            <Label text="32s" styleClass="rank-score-green"/>
                                            <Label text="98,420" styleClass="rank-meta"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="rank-row">
                                        <Label text="2" styleClass="rank-badge-silver"/>
                                        <VBox spacing="1">
                                            <Label text="BombDisposer" styleClass="rank-name"/>
                                            <Label text="LV.38" styleClass="rank-meta"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="1">
                                            <Label text="38s" styleClass="rank-score-green"/>
                                            <Label text="87,310" styleClass="rank-meta"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="rank-row">
                                        <Label text="3" styleClass="rank-badge-bronze"/>
                                        <VBox spacing="1">
                                            <Label text="GridMaster_VN" styleClass="rank-name"/>
                                            <Label text="LV.35" styleClass="rank-meta"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="1">
                                            <Label text="41s" styleClass="rank-score-green"/>
                                            <Label text="76,100" styleClass="rank-meta"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="rank-row">
                                        <Label text="4" styleClass="rank-badge-blue"/>
                                        <VBox spacing="1">
                                            <Label text="QuantumSweep" styleClass="rank-name"/>
                                            <Label text="LV.31" styleClass="rank-meta"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="1">
                                            <Label text="45s" styleClass="rank-score-green"/>
                                            <Label text="65,200" styleClass="rank-meta"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="rank-row">
                                        <Label text="5" styleClass="rank-badge-blue"/>
                                        <VBox spacing="1">
                                            <Label text="ShadowMiner" styleClass="rank-name"/>
                                            <Label text="LV.28" styleClass="rank-meta"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox alignment="CENTER_RIGHT" spacing="1">
                                            <Label text="48s" styleClass="rank-score-green"/>
                                            <Label text="54,800" styleClass="rank-meta"/>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="14" styleClass="side-panel">
                                <padding>
                                    <Insets top="18" right="18" bottom="18" left="18"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Label text="⚭" styleClass="section-icon-purple"/>
                                        <Label text="THÀNH TÍCH" styleClass="section-title-purple"/>
                                    </HBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Xem tất cả ›" styleClass="side-link"/>
                                </HBox>

                                <VBox spacing="8">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="achievement-unlocked">
                                        <Label text="⚡" styleClass="achievement-icon"/>
                                        <VBox spacing="1">
                                            <Label text="Tốc Độ Ánh Sáng" styleClass="achievement-title"/>
                                            <Label text="Hoàn thành Easy &lt; 30s" styleClass="achievement-desc"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="●" styleClass="achievement-dot"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="achievement-unlocked">
                                        <Label text="◆" styleClass="achievement-icon-blue"/>
                                        <VBox spacing="1">
                                            <Label text="Hoàn Hảo" styleClass="achievement-title"/>
                                            <Label text="0 lần đánh dấu sai" styleClass="achievement-desc"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="●" styleClass="achievement-dot"/>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="achievement-locked">
                                        <Label text="🔥" styleClass="locked-icon"/>
                                        <VBox spacing="1">
                                            <Label text="Bất Bại" styleClass="locked-title"/>
                                            <Label text="10 trận thắng liên tiếp" styleClass="locked-desc"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="achievement-locked">
                                        <Label text="♛" styleClass="locked-icon"/>
                                        <VBox spacing="1">
                                            <Label text="Huyền Thoại" styleClass="locked-title"/>
                                            <Label text="Đạt Top 10 BXH" styleClass="locked-desc"/>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="8" styleClass="challenge-panel">
                                <padding>
                                    <Insets top="17" right="17" bottom="17" left="17"/>
                                </padding>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="⚡" styleClass="challenge-icon"/>
                                    <Label text="THÁCH THỨC HẰNG NGÀY" styleClass="challenge-title"/>
                                </HBox>
                                <Label text="Expert mode · No Flags · Under 60s" styleClass="challenge-meta"/>
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2">
                                        <Label text="+5,000 XP" styleClass="challenge-xp"/>
                                        <Label text="Đặc biệt hôm nay" styleClass="challenge-note"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="THAM GIA" onAction="#onJoinChallenge" styleClass="challenge-button"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>
